# Copy this file to ".env" and fill in your own values.
# The .env file holds secrets and must NEVER be committed (see .gitignore).

# --- PayPal credentials -------------------------------------------------
# Get these from https://developer.paypal.com/dashboard/applications
#
# !!! LIVE MODE — real money !!!
# For live payments you MUST use *live* credentials from a PayPal
# *Business* account (toggle the dashboard from Sandbox to Live).
# To test first without charging real cards, use *sandbox* credentials
# and set PAYPAL_ENV=sandbox below.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# "live" (real money) or "sandbox" (test money).
PAYPAL_ENV=live

# Currency for charges. The catalogue prices are in USD; only change this
# if you also convert the prices — there is no FX conversion here.
CURRENCY=USD

# --- MongoDB Atlas ------------------------------------------------------
# Where captured orders are stored. Get this from your Atlas cluster:
#   Atlas -> Database -> Connect -> Drivers -> copy the connection string,
#   then replace <password> with your DB user's password.
# Example:
#   mongodb+srv://appuser:s3cr3t@cluster0.abcde.mongodb.net/?retryWrites=true&w=majority
# Leave blank to run without saving orders (payments still work).
MONGODB_URI=
MONGODB_DB=busterzworld

# --- Admin dashboard ----------------------------------------------------
# Login for the admin panel at http://localhost:3000/admin/
# Pick a strong password. Admin login is disabled until ADMIN_PASSWORD is set.
ADMIN_USER=admin
ADMIN_PASSWORD=
# Secret used to sign admin session tokens. Set any long random string.
# If left blank, the PayPal secret is used as a fallback.
ADMIN_SECRET=

# Port the server listens on.
PORT=3000
